# =============================================================================
# .env.example — copy to .env and fill in your values
# All paths may be absolute or relative to the project root.
# =============================================================================

# --- Directories -------------------------------------------------------------
DATA_DIR=./_data
OUTPUT_DIR=./_output
MANUAL_DATA_DIR=./data_manual

# --- Analysis period ---------------------------------------------------------
START_DATE=1913-01-01
END_DATE=2024-12-31

# --- BIS date ranges ---------------------------------------------------------
# Domestic Debt Securities (WS_NA_SEC_DSS) pull window
BIS_DOMESTIC_START=2003-12-25
BIS_DOMESTIC_END=2024-12-31

# International Debt Securities foreign-currency slice (WS_DEBT_SEC2_PUB)
BIS_IDS_START=2003-Q1
BIS_IDS_END=2024-Q4

# --- WRDS credentials (required only for MSCI/Datastream pulls) -------------
# Register at https://wrds-www.wharton.upenn.edu/
WRDS_USERNAME=your_wrds_username
WRDS_PASSWORD=your_wrds_password
